<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Merge_Action__c</fullName>
    <description>Whether to keep the duplicate row after field merge only, or also reparent related records and delete the duplicate.</description>
    <inlineHelpText>Select how related records should be handled when the merge runs.</inlineHelpText>
    <label>Merge Action</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Merge_Reparent_and_Delete</fullName>
                <default>true</default>
                <label>Merge, Reparent and Delete</label>
            </value>
            <value>
                <fullName>Merge_and_Keep</fullName>
                <default>false</default>
                <label>Merge and Keep</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
